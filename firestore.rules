// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: /users/{userId}
// Document ID: userId (UID)
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - balance: number (required)
//   - totalEarned: number (required)
//   - totalWithdrawn: number (required)
//   - role: string (required, 'user' | 'admin')
//   - createdAt: string (required, ISO 8601)
//
// Collection: /ads/{adId}
// Document ID: auto-generated
// Fields:
//   - id: string (required)
//   - title: string (required)
//   - description: string (optional)
//   - reward: number (required)
//   - duration: number (required)
//   - url: string (required)
//   - active: boolean (required)
//   - createdAt: string (required, ISO 8601)
//
// Collection: /withdrawals/{withdrawalId}
// Document ID: auto-generated
// Fields:
//   - id: string (required)
//   - userId: string (required)
//   - userEmail: string (optional)
//   - amount: number (required)
//   - fee: number (required)
//   - netAmount: number (required)
//   - status: string (required, 'pending' | 'approved' | 'rejected')
//   - statusUpdatedAt: string (optional, ISO 8601)
//   - trxId: string (optional)
//   - method: string (required)
//   - accountTitle: string (required)
//   - accountNumber: string (required)
//   - createdAt: string (required, ISO 8601)
//
// Collection: /adViews/{viewId}
// Document ID: auto-generated
// Fields:
//   - id: string (required)
//   - userId: string (required)
//   - adId: string (required)
//   - reward: number (required)
//   - timestamp: string (required, ISO 8601)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "kousaryoukhainda@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'balance', 'totalEarned', 'totalWithdrawn', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.balance is number &&
             data.totalEarned is number &&
             data.totalWithdrawn is number &&
             data.role in ['user', 'admin'] &&
             data.createdAt is string;
    }

    function isValidAd(data) {
      return data.keys().hasAll(['id', 'title', 'reward', 'duration', 'url', 'active', 'createdAt']) &&
             data.id is string &&
             data.title is string && data.title.size() > 0 &&
             data.reward is number &&
             data.duration is number &&
             data.url is string &&
             data.active is bool &&
             data.createdAt is string;
    }

    function isValidWithdrawal(data) {
      // Get settings for validation
      let settings = get(/databases/$(database)/documents/settings/global).data;
      let minWithdrawal = settings != null ? settings.minWithdrawal : 100;
      let feePercentage = settings != null ? settings.withdrawalFeePercentage : 10;
      
      // Calculate expected fee and netAmount
      let expectedFee = data.amount * (feePercentage / 100.0);
      let expectedNetAmount = data.amount - expectedFee;
      
      return data.keys().hasAll(['id', 'userId', 'amount', 'fee', 'netAmount', 'status', 'method', 'accountTitle', 'accountNumber', 'createdAt']) &&
             data.id is string &&
             (data.userId == request.auth.uid || isAdmin()) &&
             data.amount is number && 
             data.amount >= minWithdrawal &&
             data.amount <= 50000 &&  // Max withdrawal limit
             // Enforce server-calculated fee (within 1% tolerance for rounding)
             (data.fee >= expectedFee * 0.99 && data.fee <= expectedFee * 1.01) &&
             // Enforce server-calculated netAmount (within 1% tolerance for rounding)
             (data.netAmount >= expectedNetAmount * 0.99 && data.netAmount <= expectedNetAmount * 1.01) &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.method in ['Jazz cash', 'Easy Paisa', 'Naya Pay', 'Sada Pay'] &&
             data.accountTitle is string && data.accountTitle.size() > 0 &&
             data.accountNumber is string && data.accountNumber.size() > 0 &&
             data.createdAt is string &&
             (!('statusUpdatedAt' in data) || data.statusUpdatedAt is string) &&
             (!('userEmail' in data) || data.userEmail is string) &&
             (!('trxId' in data) || data.trxId is string);
    }

    function isValidAdView(data) {
      // Get settings for max reward validation
      let settings = get(/databases/$(database)/documents/settings/global).data;
      let maxAdReward = settings != null ? settings.adReward : 10;
      
      // Verify ad exists and is active
      let ad = get(/databases/$(database)/documents/ads/$(data.adId)).data;
      let adExists = ad != null;
      let adIsActive = adExists ? ad.active == true : false;
      let adRewardValid = adExists ? data.reward <= ad.reward : false;
      
      return data.keys().hasAll(['id', 'userId', 'adId', 'reward', 'timestamp']) &&
             data.keys().hasOnly(['id', 'userId', 'adId', 'reward', 'timestamp']) &&
             data.id is string &&
             data.userId == request.auth.uid &&
             data.adId is string && data.adId.size() > 0 &&
             data.reward is number && 
             data.reward >= 0 && 
             data.reward <= maxAdReward &&
             // Ensure reward matches the ad's reward (within 1% tolerance)
             adRewardValid &&
             data.timestamp is string &&
             // Only allow create if ad exists and is active
             (adExists && adIsActive);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) &&
        (request.resource.data.role == 'user' || (request.resource.data.role == 'admin' && request.auth.token.email == "kousaryoukhainda@gmail.com"));
      allow update: if isAuthenticated() && (
        // Owner can only be updated by admin (for balance changes via withdrawals)
        // Users cannot directly modify their own balance
        (isAdmin() && request.resource.data.role == resource.data.role) ||
        // Allow balance updates only through increment operations (handled by Cloud Functions)
        // This is enforced by checking that only specific fields change
        (isOwner(userId) && 
         request.resource.data.balance == resource.data.balance &&
         request.resource.data.totalEarned == resource.data.totalEarned &&
         request.resource.data.totalWithdrawn == resource.data.totalWithdrawn &&
         request.resource.data.role == resource.data.role)
      );
    }

    match /ads/{adId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidAd(request.resource.data);
      allow delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data) && request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidWithdrawal(request.resource.data);
    }

    match /adViews/{viewId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidAdView(request.resource.data) &&
        // Prevent duplicate views - check no existing view with same userId and adId
        !exists(/databases/$(database)/documents/adViews) || 
        (
          // This is a limitation - we can't query in rules, so we rely on unique ID pattern
          // Client should use a deterministic ID: ${userId}_${adId}
          request.resource.data.userId == request.auth.uid
        );
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
