// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: /users/{userId}
// Document ID: userId (UID)
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - balance: number (required)
//   - totalEarned: number (required)
//   - totalWithdrawn: number (required)
//   - role: string (required, 'user' | 'admin')
//   - createdAt: string (required, ISO 8601)
//
// Collection: /ads/{adId}
// Document ID: auto-generated
// Fields:
//   - id: string (required)
//   - title: string (required)
//   - description: string (optional)
//   - reward: number (required)
//   - duration: number (required)
//   - url: string (required)
//   - active: boolean (required)
//   - createdAt: string (required, ISO 8601)
//
// Collection: /withdrawals/{withdrawalId}
// Document ID: auto-generated
// Fields:
//   - id: string (required)
//   - userId: string (required)
//   - userEmail: string (optional)
//   - amount: number (required)
//   - fee: number (required)
//   - netAmount: number (required)
//   - status: string (required, 'pending' | 'approved' | 'rejected')
//   - statusUpdatedAt: string (optional, ISO 8601)
//   - trxId: string (optional)
//   - method: string (required)
//   - accountTitle: string (required)
//   - accountNumber: string (required)
//   - createdAt: string (required, ISO 8601)
//
// Collection: /adViews/{viewId}
// Document ID: auto-generated
// Fields:
//   - id: string (required)
//   - userId: string (required)
//   - adId: string (required)
//   - reward: number (required)
//   - timestamp: string (required, ISO 8601)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "kousaryoukhainda@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'balance', 'totalEarned', 'totalWithdrawn', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.balance is number &&
             data.totalEarned is number &&
             data.totalWithdrawn is number &&
             data.role in ['user', 'admin'] &&
             data.createdAt is string;
    }

    function isValidAd(data) {
      return data.keys().hasAll(['id', 'title', 'reward', 'duration', 'url', 'active', 'createdAt']) &&
             data.id is string &&
             data.title is string && data.title.size() > 0 &&
             data.reward is number &&
             data.duration is number &&
             data.url is string &&
             data.active is bool &&
             data.createdAt is string;
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['id', 'userId', 'amount', 'fee', 'netAmount', 'status', 'method', 'accountTitle', 'accountNumber', 'createdAt']) &&
             data.id is string &&
             (data.userId == request.auth.uid || isAdmin()) &&
             data.amount is number && data.amount >= 100 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.method is string &&
             data.accountTitle is string && data.accountTitle.size() > 0 &&
             data.accountNumber is string && data.accountNumber.size() > 0 &&
             data.createdAt is string &&
             (!('statusUpdatedAt' in data) || data.statusUpdatedAt is string) &&
             (!('userEmail' in data) || data.userEmail is string) &&
             (!('trxId' in data) || data.trxId is string);
    }

    function isValidAdView(data) {
      return data.keys().hasAll(['id', 'userId', 'adId', 'reward', 'timestamp']) &&
             data.keys().hasOnly(['id', 'userId', 'adId', 'reward', 'timestamp']) &&
             data.id is string &&
             data.userId == request.auth.uid &&
             data.adId is string &&
             data.reward is number && data.reward >= 0 &&
             data.timestamp is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && 
        (request.resource.data.role == 'user' || (request.resource.data.role == 'admin' && request.auth.token.email == "kousaryoukhainda@gmail.com"));
      allow update: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) ||
        isAdmin()
      );
    }

    match /ads/{adId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidAd(request.resource.data);
      allow delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data) && request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidWithdrawal(request.resource.data);
    }

    match /adViews/{viewId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidAdView(request.resource.data);
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
